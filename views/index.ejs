<%- include('partials/head') %>
<body>
  <div class="wrapper">
    <%- include('partials/header') %>
    <%- include('partials/nav') %>

    <main>
      <h1>Welcome to CSE Motors!</h1>

      <section class="hero">
        <div class="text">
          <h2 style="color: #00bcd4;">DMC Delorean</h2>
          <p>3 Cup holders</p>
          <p>Superman doors</p>
          <p>Fuzzy dice!</p>          
          <button>Own Today</button>
        </div>
        <div class="car-img">
          <img src="/images/delorean.jpg" alt="DMC Delorean">
        </div>
      </section>

      <div class="upgrade-review-container">
        <section class="upgrades">
          <h3>Delorean Upgrades</h3>
          <div class="grid">
            <div class="upgrade-item">
              <img src="/images/flux-capacitor.webp" alt="Flux Capacitor">
              <p class="upgrade-label"><a href="#">Flux Capacitor</a></p>
            </div>
          
            <div class="upgrade-item">
              <img src="/images/flame.png" alt="Flame Decals">
              <p class="upgrade-label"><a href="#">Flame Decals</a></p>
            </div>
          
            <div class="upgrade-item">
              <img src="/images/bumper-sticker.jpg" alt="Bumper Stickers">
              <p class="upgrade-label"><a href="#">Bumper Stickers</a></p>
            </div>
          
            <div class="upgrade-item">
              <img src="/images/hub-cap.jpg" alt="Hub Caps">
              <p class="upgrade-label"><a href="#">Hub Caps</a></p>
            </div>
          </div>            
        </section>

        <section class="reviews">
          <h3>DMC Delorean Reviews</h3>
          <ul>
            <li>"So fast it's almost like traveling in time." (4/5)</li>
            <li>"Coolest ride on the road." (4/5)</li>
            <li>"I'm feeling McFly!" (5/5)</li>
            <li>"The most futuristic ride of our day." (4.5/5)</li>
            <li>"80's livin and I love it!" (5/5)</li>
          </ul>
        </section>
      </div>
    </main>

    <%- include('partials/footer') %>
  </div>
</body>
</html>
